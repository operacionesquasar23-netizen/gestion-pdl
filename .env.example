# Supabase - obtén estos valores en supabase.com > tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJXXXX...

# Clave secreta de Supabase (solo para server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJXXXX...

# Resend - obtén tu API key en resend.com
RESEND_API_KEY=re_XXXX...

# Correo desde donde se envían las notificaciones
FROM_EMAIL=noreply@tuempresa.com

# Correo del administrador (quien gestiona los PDL)
ADMIN_EMAIL=admin@tuempresa.com

# URL de producción (para links en correos)
NEXT_PUBLIC_APP_URL=https://pdl-tuempresa.vercel.app

# PIN secreto para acceder al panel de administrador
ADMIN_PIN=1234
